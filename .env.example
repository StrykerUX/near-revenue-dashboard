# Live API access — optional. Without a valid key the dashboard falls back to
# the static mock data in src/lib/data.ts and still renders correctly.
NEAR_API_KEY=
NEAR_API_BASE_URL=https://revenue-dashboard-api-production.up.railway.app

# Used as metadataBase for Open Graph / Twitter card URLs.
NEXT_PUBLIC_SITE_URL=https://revenue.near.org

# Shows extra nav links (Dashboard / Analytics / Data Guide) and a green/red
# glow indicating whether each stat card is fed by the live API or a static
# fallback. Keep false in production.
NEXT_PUBLIC_DEBUG_SOURCES=false
